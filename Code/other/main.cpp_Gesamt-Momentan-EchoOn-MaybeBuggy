void handleUsedPowerData(){
  // We need to get rid of 13 Bytes after the marker
  // -> 64 1C 00 04 72 62 01 65 03 5A 58 BE 62
  for(int i = 0; i < 19; i++){
    Serial.print("Currently discarding: ");
    Serial.print(Serial2.read());
    Serial.println();
  }

  // now gather 4 bytes, the wanted data
  for(int i = 0; i < 4; i++){
    usedPowerBuffer[usedPowerBufferIndex] = Serial2.read();

    Serial.print("got usedPower from serial: ");
    Serial.println(usedPowerBuffer[usedPowerBufferIndex]);
    usedPowerBufferIndex++;
  }
  usedPower = (usedPowerBuffer[0] << 24 | usedPowerBuffer[1] << 16 | usedPowerBuffer[2] << 8 | usedPowerBuffer[3]); //merge 4 bytes into single variable to calculate power value
  
  // DEBUGhhhh
  Serial.print("usedPower as HEX: "); // 10376CA
  Serial.println(usedPower, HEX);

  Serial.print("usedPower as DEC: "); // 17004234
  Serial.println(usedPower, DEC);

  // DEBUGhhh end
  usedPowerkWh = usedPower / 10000;
  Serial.print("Gesamtverbrauch (DEC): "); // 1700 kWh
  Serial.println(usedPowerkWh);
}

void handleCurrentPowerData(){
  // We need to get rid of 8 Bytes after the marker
  // -> 01 01 62 1B 52 00 53
  for(int i = 0; i < 7; i++){
    Serial.print("Currently discarding: ");
    Serial.print(Serial2.read());
    Serial.println();
  }

  // now gather 2 bytes, the wanted data
  for(int i = 0; i < 2; i++){
    currentPowerBuffer[currentPowerBufferIndex] = Serial2.read();

    Serial.print("got CurrentPower from serial: ");
    Serial.println(currentPowerBuffer[currentPowerBufferIndex]);
    currentPowerBufferIndex++;
  }
  currentPower = (currentPowerBuffer[0] << 8 | currentPowerBuffer[1]); //merge 2 bytes into single variable to calculate power value
  
  // DEBUGhhhh
  Serial.print("CurrentPower as HEX: "); //
  Serial.println(currentPower, HEX);

  Serial.print("CurrentPower as DEC: "); //
  Serial.println(currentPower, DEC);

  // DEBUGhhh end
  Serial.print("Momentanverbrauch (DEC): "); //
  Serial.println(currentPower);
}


