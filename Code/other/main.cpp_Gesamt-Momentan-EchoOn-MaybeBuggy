void loop() {

  while (Serial2.available() > 0 && continueSearch == true){

    // SML Start
    Serial.println("Searching startMarker");
    while (findSmlStartMarkerMissing == true){
      
      //continueFilling = true; // allow searching for marker for following function
      findSmlStartMarker(); // after it we found the SML start block
    }
    Serial.println("Found startMarker");

    // Gesamtverbrauch
    Serial.println("Searching usedPowerMarker");
    while (findbeforeUsedPowerMarkerMissing == true){
      continueFilling = true; // allow searching for marker for following function
      findbeforeUsedPowerMarker(); // after it we found the beginning of the 1.8.0 block
    }
    Serial.println("Found usedPowerMarker");

    Serial.println("Extracting handleUsedPowerData");
    handleUsedPowerData();


    // Aktueller Verbrauch
    Serial.println("Searching CurrentPowerMarker");
    while (findbeforeCurrentPowerMarkerMissing == true){
      continueFilling = true; // allow searching for marker for following function
      findbeforeCurrentPowerMarker(); // after it we found the beginning of the 1.8.0 block
    }
    Serial.println("Found CurrentPowerMarker");

    Serial.println("Extracting handleCurrentPowerData");
    handleCurrentPowerData();

    continueSearch = false;

  }

  // Debug only
  continueSearch = true;

}
