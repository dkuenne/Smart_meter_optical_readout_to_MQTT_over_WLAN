    beforeCurrentPowerMarkerBuffer[tempCurrentPowerArrayIndexToWrite] = serialByteBuffer[0];

    // Read and compare
    // Since we know the end position after filling we fill the array to compare backwards to keep the right direction of data
    tempCurrentPowerArrayIndexToRead = tempCurrentPowerArrayIndexToWrite;

    beforeCurrentPowerMarkerCompareBufferIndex = 7;
    for (int i2 = 0; i2 < 8 && continueFilling == true; i2++)
    {

      // Check if we are at the beginning of the array, if yes start at the end
      if (tempCurrentPowerArrayIndexToRead == -1)
      {
        tempCurrentPowerArrayIndexToRead = sizeof(beforeCurrentPowerMarkerBuffer) - 1; // Arrays are 0-7 for 8 parts so max. position is 7
      }

      beforeCurrentPowerMarkerCompareBuffer[beforeCurrentPowerMarkerCompareBufferIndex] = beforeCurrentPowerMarkerBuffer[tempCurrentPowerArrayIndexToRead];

      // Compare and break loop if found
      status = memcmp(beforeCurrentPowerMarker, beforeCurrentPowerMarkerCompareBuffer, sizeof(beforeCurrentPowerMarker));
      if (status == 0)
        continueFilling = false;
      if (status == 0)
        findbeforeCurrentPowerMarkerMissing = false;
      else
        ;

      // Step one position back in array
      beforeCurrentPowerMarkerCompareBufferIndex--;
      tempCurrentPowerArrayIndexToRead--;
    }

    // Write at next position in array
    tempCurrentPowerArrayIndexToWrite++;
  }
}


