void findbeforeUsedPowerMarker()
{

  // Fill buffer with serial data byte by byte and compare
  while (continueFilling == true)
  {

    // Fill buffer
    // Check if at the end first
    if (tempArrayIndexToWrite == sizeof(beforeUsedPowerMarkerBuffer))
    {
      tempArrayIndexToWrite = 0;
    }

    // Read one byte, place it into buffer and fill array with it
    irLesekopf.readBytes(serialByteBuffer, 1);
    beforeUsedPowerMarkerBuffer[tempArrayIndexToWrite] = serialByteBuffer[0];

    // Read and compare
    // Since we know the end position after filling we fill the array to compare backwards to keep the right direction of data
    tempArrayIndexToRead = tempArrayIndexToWrite;

    beforeUsedPowerMarkerCompareBufferIndex = 7;
    for (int i2 = 0; i2 < 8 && continueFilling == true; i2++)
    {

      // Check if we are at the beginning of the array, if yes start at the end
      if (tempArrayIndexToRead == -1)
      {
        tempArrayIndexToRead = sizeof(beforeUsedPowerMarkerBuffer) - 1; // Arrays are 0-7 for 8 parts so max. position is 7
      }

      beforeUsedPowerMarkerCompareBuffer[beforeUsedPowerMarkerCompareBufferIndex] = beforeUsedPowerMarkerBuffer[tempArrayIndexToRead];

      // Compare and break loop if found
      status = memcmp(beforeUsedPowerMarker, beforeUsedPowerMarkerCompareBuffer, sizeof(beforeUsedPowerMarker));
      if (status == 0)
        continueFilling = false;
      if (status == 0)
        findbeforeUsedPowerMarkerMissing = false;
      else
        ;

      // Step one position back in array
      beforeUsedPowerMarkerCompareBufferIndex--;
      tempArrayIndexToRead--;
    }

    // Write at next position in array
    tempArrayIndexToWrite++;
  }
}

void findbeforeCurrentPowerMarker()
{

  // Fill buffer with serial data byte by byte and compare
  while (continueFilling == true)
  {

    // Fill buffer
    // Check if at the end first
    if (tempCurrentPowerArrayIndexToWrite == sizeof(beforeCurrentPowerMarkerBuffer))
