void setup()
{

  // ########## START - ADC init ##########
  pinMode(A0, INPUT);
  // ########## END - ADC init ##########


  // ########## START - LoRa init ##########
  // Enable module and give it time to boot
  pinMode(loRaModuleM0, OUTPUT);
  pinMode(loRaModuleM1, OUTPUT);
  digitalWrite(loRaModuleM0, LOW);
  digitalWrite(loRaModuleM1, LOW);
  delay(500);
  // ########## END - LoRa init ##########


  // ########## START - UART init ##########
  Serial.begin(115200);

  // Configure irLesekopf on pins RX=D7 and TX=D6 (-1, -1 means use the default)
  // This port is also used for ESP32 debug msg @ 115200 so it looks like it sends garbage at every boot.
  // We don't want to send anyways.
  irLesekopf.begin(9600, SERIAL_8N1, D7, D6);

  // Configure loraModul on pins RX=D10, TX=D9
  // D10 gets high while initializing, which can be seen as a bit by the receiver.
  // This doesn't happen if we switch pins. Trick from SoftwareSerial lib (setting pin high before initializing) didn't work here.
  loraModul.begin(115200, SERIAL_8N1, D10, D9);
  //loraModul.println(F("MQTT SML PowerMeter"));

  // ########## END - UART init ##########


  // ########## START - Measure ADC ##########
  uint32_t batteryVoltageRead = 0;
  for(int i = 0; i < 16; i++) {
      batteryVoltageRead = batteryVoltageRead + analogReadMilliVolts(A0); // ADC with correction   
  }
  batteryVoltage = 2 * batteryVoltageRead / 16 / 1000.0; // attenuation ratio 1/2, mV --> V
  loraModul.print("<01;03;");
  loraModul.print(batteryVoltage);
  loraModul.println(">");
  /*  Debugging
  Serial.print("Battery Voltage = ");
  Serial.print(batteryVoltage);
  Serial.println(" V");
  */
  // ########## END - Measure ADC ##########


  // ########## START - Get data ##########
  delay(500);
  while (irLesekopf.available() > 0 && continueSearch == true)
  {

    // Gesamtverbrauch
    while (findbeforeUsedPowerMarkerMissing == true)
    {
      continueFilling = true;      // allow searching for marker for following function
      findbeforeUsedPowerMarker(); // after it we found the beginning of the 1.8.0 block
    }

    handleUsedPowerData();

    // Aktueller Verbrauch
    while (findbeforeCurrentPowerMarkerMissing == true)
    {
      continueFilling = true;         // allow searching for marker for following function
      findbeforeCurrentPowerMarker(); // after it we found the beginning of the 16.7.0 block
    }

    handleCurrentPowerData();

    continueSearch = false;

    ///*DEBUG
    // ########## START - Shutdown LoRA Module ##########
    // Small delay to make sure all data was transmitted
    delay(2000);
    digitalWrite(loRaModuleM0, LOW);
    digitalWrite(loRaModuleM1, LOW);
    // ########## END - Shutdown LoRA Module ##########


    // ########## START - Deep Sleep ##########
    //Serial.println("Deep sleep for 60 seconds");
    //loraModul.println("DEEP SLEEP");
    ESP.deepSleep(50e6); //10s + 50s = 60s
    // ########## END - Deep Sleep ##########
    //*/
  }
  // ########## END - Get data ##########


}



