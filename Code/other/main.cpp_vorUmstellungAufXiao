// Includes
#include <Arduino.h>
#include <SoftwareSerial.h>

SoftwareSerial loRaModule;
const int loRaModuleM0 = 32;
const int loRaModuleM1 = 33;

byte serialByteBuffer[5]; // Buffer for receiving serial data
int startArrayIndex = 0;
int stopArrayIndex = 0;

const byte beforeUsedPowerMarker[] = {0x77, 0x07, 0x01, 0x00, 0x01, 0x08, 0x00, 0xFF}; // 77070100010800FF
byte beforeUsedPowerMarkerBuffer[8];
byte beforeUsedPowerMarkerCompareBuffer[8];

const byte beforeCurrentPowerMarker[] = {0x77, 0x07, 0x01, 0x00, 0x10, 0x07, 0x00, 0xFF}; // 77070100100700FF
byte beforeCurrentPowerMarkerBuffer[8];
byte beforeCurrentPowerMarkerCompareBuffer[8];

// Ring Buffer
int tempArrayIndexToWrite = 0;             // Array position for writing
int tempArrayIndexToRead = 0;              // Array position for reading
int tempCurrentPowerArrayIndexToWrite = 0; // Array position for writing
int tempCurrentPowerArrayIndexToRead = 0;  // Array position for reading
int beforeUsedPowerMarkerCompareBufferIndex = 7;
int beforeCurrentPowerMarkerCompareBufferIndex = 7;
bool continueFilling = true; // Stop getting data if marker was found
bool findbeforeUsedPowerMarkerMissing = true;
bool findbeforeCurrentPowerMarkerMissing = true;
int status;

// Received 1.8.0 data (Gesamtverbrauch)
byte usedPowerBuffer[8];
int usedPowerBufferIndex = 0;
int usedPower;
long usedPowerkWh;

// Received 16.7.0 data (Momentanverbrauch)
byte currentPowerBuffer[4];
int currentPowerBufferIndex = 0;
int currentPower;

bool continueSearch = true;

void findbeforeUsedPowerMarker()
{

  // Fill buffer with serial data byte by byte and compare
  while (continueFilling == true)
  {

    // Fill buffer
    // Check if at the end first
    if (tempArrayIndexToWrite == sizeof(beforeUsedPowerMarkerBuffer))
    {
      tempArrayIndexToWrite = 0;
    }

    // Read one byte, place it into buffer and fill array with it
    Serial2.readBytes(serialByteBuffer, 1);
    beforeUsedPowerMarkerBuffer[tempArrayIndexToWrite] = serialByteBuffer[0];

    // Read and compare
    // Since we know the end position after filling we fill the array to compare backwards to keep the right direction of data
    tempArrayIndexToRead = tempArrayIndexToWrite;

    beforeUsedPowerMarkerCompareBufferIndex = 7;
    for (int i2 = 0; i2 < 8 && continueFilling == true; i2++)
    {

      // Check if we are at the beginning of the array, if yes start at the end
      if (tempArrayIndexToRead == -1)
      {
        tempArrayIndexToRead = sizeof(beforeUsedPowerMarkerBuffer) - 1; // Arrays are 0-7 for 8 parts so max. position is 7
      }

      beforeUsedPowerMarkerCompareBuffer[beforeUsedPowerMarkerCompareBufferIndex] = beforeUsedPowerMarkerBuffer[tempArrayIndexToRead];

      // Compare and break loop if found
      status = memcmp(beforeUsedPowerMarker, beforeUsedPowerMarkerCompareBuffer, sizeof(beforeUsedPowerMarker));
      if (status == 0)
        continueFilling = false;
      if (status == 0)
        findbeforeUsedPowerMarkerMissing = false;
      else
        ;

      // Step one position back in array
      beforeUsedPowerMarkerCompareBufferIndex--;
      tempArrayIndexToRead--;
    }

    // Write at next position in array
    tempArrayIndexToWrite++;
  }
}

