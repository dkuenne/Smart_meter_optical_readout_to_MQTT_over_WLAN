void setup()
{

  // ########## START - Serial init ##########
  Serial.begin(115200);
  Serial2.begin(9600);

  // Enable module
  pinMode(loRaModuleM0, OUTPUT);
  pinMode(loRaModuleM1, OUTPUT);
  digitalWrite(loRaModuleM0, LOW);
  digitalWrite(loRaModuleM1, LOW);

  Serial.println(F("MQTT SML PowerMeter"));

  // Setting output pin high before initializing prevents sending of invalid first byte
  // https://github.com/plerup/espsoftwareserial/issues/254
  digitalWrite(26, HIGH);
  loRaModule.begin(115200, SWSERIAL_8N1, 25, 26);
  //  DEBUG
  // Serial connection seems to be unreliable without delay between initializing serial port and sending data
  //delay(15);
  //loRaModule.println("MQTT SML PowerMeter"); 
  // ########## END - Serial init ##########


  // ########## START - Get data ##########
  while (Serial2.available() > 0 && continueSearch == true)
  {

    // Falls zu langsam gefüllt
    // delay(20);

    // Gesamtverbrauch
    // Serial.println("Searching usedPowerMarker");
    while (findbeforeUsedPowerMarkerMissing == true)
    {
      continueFilling = true;      // allow searching for marker for following function
      findbeforeUsedPowerMarker(); // after it we found the beginning of the 1.8.0 block
    }

    // Serial.println("Extracting handleUsedPowerData");
    handleUsedPowerData();

    // Falls zu langsam gefüllt
    // delay(20);
    // Aktueller Verbrauch
    // Serial.println("Searching currentPowerMarker");
    while (findbeforeCurrentPowerMarkerMissing == true)
    {
      continueFilling = true;         // allow searching for marker for following function
      findbeforeCurrentPowerMarker(); // after it we found the beginning of the 16.7.0 block
    }

    // Serial.println("Extracting handleUsedPowerData");
    handleCurrentPowerData();

    continueSearch = false;
  }
  // ########## END - Get data ##########


  // ########## START - Shutdown LoRA Module ##########
  digitalWrite(loRaModuleM0, LOW);
  digitalWrite(loRaModuleM1, LOW);
  // ########## END - Shutdown LoRA Module ##########


  // ########## START - Deep Sleep ##########
  //Serial.println("Deep sleep for 292 (5min) seconds");
  //ESP.deepSleep(292e6);
  ESP.deepSleep(50e6); //10s + 50s = 60s
  // ########## END - Deep Sleep ##########

}



